# GOOGLE_GENAI_USE_VERTEXAI: Tells @google/genai to route through Vertex AI rather than Gemini Developer API.
GOOGLE_GENAI_USE_VERTEXAI=True

# GOOGLE_CLOUD_PROJECT: The active Google Cloud Project ID used to bill and authenticate Vertex AI API calls.
GOOGLE_CLOUD_PROJECT=project-41ceb22a-f998-416d-98b

# GOOGLE_CLOUD_LOCATION: The Google Cloud and Vertex AI region location to resolve prediction requests (defaults to 'global').
GOOGLE_CLOUD_LOCATION=global

# PORT: The port that the Express + Vite server listens to for server-side responses.
PORT=8080
